# =============================================================================
# Docker Compose Environment Variables
# Copy this file to .env and fill in the values before running docker-compose.
# =============================================================================

# --- Required (docker-compose will fail without these) ---

# PostgreSQL password for the 'gobus' user
POSTGRES_PASSWORD=change-me-to-a-strong-password

# JWT signing secret (min 32 characters)
JWT_SECRET=change-me-to-a-strong-secret-at-least-32-chars

# --- Optional (have sensible defaults) ---

# PostgreSQL host port mapping (default: 5632)
# PG_PORT=5632

# API host port mapping (default: 3100)
# API_PORT=3100

# Web frontend host port mapping (default: 7766)
# PORT=7766

# Node environment: development | production (default: production)
# NODE_ENV=production

# Allowed CORS origins (default: http://localhost:7766)
# CORS_ORIGIN=http://localhost:7766

# Log level: fatal | error | warn | info | debug | trace (default: info)
# LOG_LEVEL=info
