# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/transio

# JWT secrets (min 32 characters each, must be different from each other)
JWT_SECRET=change-me-to-a-strong-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-another-strong-secret-32-chars

# Server port (default: 3000)
PORT=3000

# Host to bind to (default: 0.0.0.0)
HOST=0.0.0.0

# Node environment: development | production | test
NODE_ENV=development

# Allowed CORS origins, comma-separated (default: http://localhost:3001)
CORS_ORIGIN=http://localhost:3001

# Log level: fatal | error | warn | info | debug | trace | silent (default: info)
LOG_LEVEL=info

# Maximum number of connections in the PostgreSQL connection pool (default: 10)
DATABASE_POOL_MAX=10
