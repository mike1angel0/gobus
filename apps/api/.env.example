# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/transio

# JWT secrets (min 16 characters)
JWT_SECRET=change-me-to-a-strong-secret
JWT_REFRESH_SECRET=change-me-to-another-strong-secret

# Server port (default: 3000)
PORT=3000

# Node environment: development | production | test
NODE_ENV=development

# Allowed CORS origin (default: http://localhost:3001)
CORS_ORIGIN=http://localhost:3001
