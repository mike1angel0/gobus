# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/transio

# JWT secrets (min 16 characters each, must be different)
JWT_SECRET=change-me-to-a-strong-secret
JWT_REFRESH_SECRET=change-me-to-another-strong-secret

# Server port (default: 3000)
PORT=3000

# Host to bind to (default: 0.0.0.0)
HOST=0.0.0.0

# Node environment: development | production | test
NODE_ENV=development

# Allowed CORS origins, comma-separated (default: http://localhost:3001)
CORS_ORIGIN=http://localhost:3001

# Log level: fatal | error | warn | info | debug | trace | silent (default: info)
LOG_LEVEL=info
