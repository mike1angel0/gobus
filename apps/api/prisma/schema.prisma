generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Role {
  PASSENGER
  PROVIDER
  DRIVER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  LOCKED
}

enum ProviderStatus {
  APPROVED
  PENDING
}

enum SeatType {
  STANDARD
  PREMIUM
  DISABLED_ACCESSIBLE
  BLOCKED
}

enum ScheduleStatus {
  ACTIVE
  CANCELLED
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum DelayReason {
  TRAFFIC
  MECHANICAL
  WEATHER
  OTHER
}

// ─── User ───────────────────────────────────────────────────────────────────

model User {
  id                  String     @id @default(cuid())
  email               String     @unique @db.VarChar(255)
  name                String     @db.VarChar(100)
  passwordHash        String     @db.VarChar(255)
  role                Role       @default(PASSENGER)
  phone               String?    @db.VarChar(20)
  avatarUrl           String?    @db.VarChar(2048)
  preferences         Json?
  providerId          String?
  status              UserStatus @default(ACTIVE)
  failedLoginAttempts Int        @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  provider            Provider?       @relation(fields: [providerId], references: [id])
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  auditLogs           AuditLog[]
  bookings            Booking[]
  driverSchedules     Schedule[]      @relation("DriverSchedules")
  sentMessages        Message[]       @relation("SentMessages")
  receivedMessages    Message[]       @relation("ReceivedMessages")

  @@index([providerId])
  @@index([role])
}

// ─── Provider ───────────────────────────────────────────────────────────────

model Provider {
  id           String         @id @default(cuid())
  name         String         @db.VarChar(200)
  logo         String?        @db.VarChar(2048)
  contactEmail String?        @db.VarChar(255)
  contactPhone String?        @db.VarChar(20)
  status       ProviderStatus @default(PENDING)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  users        User[]
  routes       Route[]
  buses        Bus[]
}

// ─── RefreshToken ───────────────────────────────────────────────────────────

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique @db.VarChar(500)
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── PasswordResetToken ─────────────────────────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique @db.VarChar(500)
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── AuditLog ───────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String   @db.VarChar(100)
  resource   String   @db.VarChar(100)
  resourceId String?  @db.VarChar(100)
  ipAddress  String?  @db.VarChar(45)
  userAgent  String?  @db.VarChar(500)
  metadata   Json?
  createdAt  DateTime @default(now())

  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

// ─── Route ─────────────────────────────────────────────────────────────────

model Route {
  id         String   @id @default(cuid())
  name       String   @db.VarChar(200)
  providerId String
  createdAt  DateTime @default(now())

  provider   Provider   @relation(fields: [providerId], references: [id])
  stops      Stop[]
  schedules  Schedule[]

  @@index([providerId])
}

// ─── Stop ──────────────────────────────────────────────────────────────────

model Stop {
  id         String @id @default(cuid())
  name       String @db.VarChar(200)
  lat        Float
  lng        Float
  orderIndex Int
  routeId    String

  route      Route  @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@index([routeId])
}

// ─── Bus ───────────────────────────────────────────────────────────────────

model Bus {
  id           String   @id @default(cuid())
  licensePlate String   @unique @db.VarChar(20)
  model        String   @db.VarChar(200)
  capacity     Int
  rows         Int
  columns      Int
  providerId   String
  createdAt    DateTime @default(now())

  provider     Provider      @relation(fields: [providerId], references: [id])
  seats        Seat[]
  schedules    Schedule[]
  tracking     BusTracking?

  @@index([providerId])
}

// ─── Seat ──────────────────────────────────────────────────────────────────

model Seat {
  id        String   @id @default(cuid())
  row       Int
  column    Int
  label     String   @db.VarChar(10)
  type      SeatType @default(STANDARD)
  price     Float    @default(0)
  isEnabled Boolean  @default(true)
  busId     String

  bus       Bus      @relation(fields: [busId], references: [id], onDelete: Cascade)

  @@index([busId])
}

// ─── Schedule ─────────────────────────────────────────────────────────────────

model Schedule {
  id            String         @id @default(cuid())
  routeId       String
  busId         String
  driverId      String?
  departureTime DateTime
  arrivalTime   DateTime
  daysOfWeek    Int[]
  basePrice     Float
  status        ScheduleStatus @default(ACTIVE)
  tripDate      DateTime
  createdAt     DateTime       @default(now())

  route         Route          @relation(fields: [routeId], references: [id])
  bus           Bus            @relation(fields: [busId], references: [id])
  driver        User?          @relation("DriverSchedules", fields: [driverId], references: [id])
  stopTimes     StopTime[]
  bookings      Booking[]
  bookingSeats  BookingSeat[]
  delays        Delay[]

  @@index([routeId])
  @@index([busId])
  @@index([driverId])
}

// ─── StopTime ─────────────────────────────────────────────────────────────────

model StopTime {
  id             String   @id @default(cuid())
  scheduleId     String
  stopName       String   @db.VarChar(200)
  arrivalTime    DateTime
  departureTime  DateTime
  orderIndex     Int
  priceFromStart Float

  schedule       Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
}

// ─── Booking ──────────────────────────────────────────────────────────────────

model Booking {
  id            String        @id @default(cuid())
  orderId       String        @unique @default(cuid())
  userId        String
  scheduleId    String
  totalPrice    Float
  status        BookingStatus @default(CONFIRMED)
  boardingStop  String        @db.VarChar(200)
  alightingStop String        @db.VarChar(200)
  tripDate      DateTime
  createdAt     DateTime      @default(now())

  user          User          @relation(fields: [userId], references: [id])
  schedule      Schedule      @relation(fields: [scheduleId], references: [id])
  bookingSeats  BookingSeat[]

  @@index([userId])
  @@index([scheduleId])
}

// ─── BookingSeat ──────────────────────────────────────────────────────────────

model BookingSeat {
  id         String @id @default(cuid())
  bookingId  String
  seatLabel  String @db.VarChar(10)
  scheduleId String
  tripDate   DateTime

  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  schedule   Schedule @relation(fields: [scheduleId], references: [id])

  @@unique([scheduleId, seatLabel, tripDate])
  @@index([bookingId])
}

// ─── Delay ────────────────────────────────────────────────────────────────────

model Delay {
  id            String      @id @default(cuid())
  scheduleId    String
  offsetMinutes Int
  reason        DelayReason
  note          String?     @db.VarChar(500)
  tripDate      DateTime
  active        Boolean     @default(true)
  createdAt     DateTime    @default(now())

  schedule      Schedule    @relation(fields: [scheduleId], references: [id])

  @@index([scheduleId])
}

// ─── BusTracking ──────────────────────────────────────────────────────────────

model BusTracking {
  id               String    @id @default(cuid())
  busId            String    @unique
  lat              Float
  lng              Float
  speed            Float
  heading          Float
  scheduleId       String?
  currentStopIndex Int
  isActive         Boolean   @default(true)
  tripDate         DateTime?
  updatedAt        DateTime  @updatedAt

  bus              Bus       @relation(fields: [busId], references: [id])
}

// ─── Message ──────────────────────────────────────────────────────────────────

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String   @db.VarChar(2000)
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])

  @@index([senderId])
  @@index([receiverId])
}
